# =========================================================================
# SAATHI - Agentic AI Financial Companion Env Configuration Template
# Duplicate this file to '.env' and fill in your values.
# =========================================================================

# AI Configuration (OpenRouter API)
# Get a free key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Configuration (Supabase PostgreSQL)
# Get credentials at https://supabase.com/
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Frontend/Backend Integration URLs
# Local development backend URL: http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000
